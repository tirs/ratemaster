# RateMaster Docker environment
# Copy to .env and adjust as needed

# Required for production
JWT_SECRET=your-secret-key-min-32-chars-for-production

# Optional: create admin on first backend startup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password

# Optional: tune these
MARKET_REFRESH_MINUTES=30
RATE_LIMIT_PER_MINUTE=120
API_CACHE_TTL_SECONDS=60

# Docker: uploads persisted in volume (backend uses /app/uploads)
# UPLOADS_DIR is set in docker-compose for backend
